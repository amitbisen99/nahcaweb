{
  "info": {
    "_postman_id": "b6f2f2b0-3a3a-4a1a-9c1a-nahca00000001",
    "name": "NAHCA API",
    "description": "Test collection for apps/api. Set `baseUrl` to wherever the API is deployed (defaults to http://localhost:4000). Register/Login requests auto-save their token into the `token` collection variable, so everything else just works once you run one of those. For admin-only endpoints, log in with an admin account and copy the returned token into the `adminToken` variable (or promote the account you just registered to admin in the DB and re-run Login).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000", "type": "string" },
    { "key": "token", "value": "", "type": "string" },
    { "key": "adminToken", "value": "", "type": "string" },
    { "key": "eventId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "API Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Confirms the API process is up and can reach the database, and reports whether Stripe/SendGrid are configured (vs placeholder keys) and whether PAYMENTS_BYPASS is on. Returns { ok: true, db: \"connected\", paymentsBypass, stripeConfigured, sendgridConfigured } or a 503 with the underlying DB error."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.token);",
                  "  console.log('Saved token for user', data.user.email);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"postman-test@example.com\",\n  \"password\": \"testpass123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] },
            "description": "Creates a new member-role account. Saves the returned token into {{token}}. Change the email if you run this more than once — it 409s on a duplicate."
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const data = pm.response.json();",
                  "  pm.collectionVariables.set('token', data.token);",
                  "  console.log('Saved token for', data.user.email, '- role:', data.user.role);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"postman-test@example.com\",\n  \"password\": \"testpass123\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] },
            "description": "Saves the returned token into {{token}}. If this account has role 'admin', also paste the token into {{adminToken}} manually to run the admin-only requests below."
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Name\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/me", "host": ["{{baseUrl}}"], "path": ["auth", "me"] }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"testpass123\",\n  \"newPassword\": \"newpass456\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/auth/change-password", "host": ["{{baseUrl}}"], "path": ["auth", "change-password"] }
          }
        }
      ]
    },
    {
      "name": "Membership Plans (public)",
      "item": [
        {
          "name": "List Membership Plans",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/membership-plans", "host": ["{{baseUrl}}"], "path": ["membership-plans"] }
          }
        },
        {
          "name": "Get Membership Plan by Type",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/membership-plans/regular", "host": ["{{baseUrl}}"], "path": ["membership-plans", "regular"] },
            "description": "type is one of: regular, student, institutional, conference"
          }
        },
        {
          "name": "Update Membership Plan (admin)",
          "request": {
            "method": "PUT",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Regular Membership\",\n  \"priceCents\": 7500,\n  \"term\": \"per year\",\n  \"note\": \"Valid for 1 year from the date you join.\",\n  \"benefits\": \"Line one\\nLine two\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/membership-plans/regular", "host": ["{{baseUrl}}"], "path": ["membership-plans", "regular"] },
            "description": "Requires {{adminToken}}. No create/delete endpoints exist by design — only these 4 plans exist and can only be updated."
          }
        }
      ]
    },
    {
      "name": "Memberships",
      "item": [
        {
          "name": "Signup (Regular tier, PAYMENTS_BYPASS)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman Member\",\n  \"email\": \"postman-member@example.com\",\n  \"password\": \"testpass123\",\n  \"type\": \"regular\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{baseUrl}}/memberships/signup", "host": ["{{baseUrl}}"], "path": ["memberships", "signup"] },
            "description": "With PAYMENTS_BYPASS=true, this creates the account and activates the membership instantly, returning a checkoutUrl that just redirects back with ?status=success. For type \"institutional\" also send studentCount (minimum comes from that plan's minStudents)."
          }
        },
        {
          "name": "Get My Memberships",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/memberships/me", "host": ["{{baseUrl}}"], "path": ["memberships", "me"] }
          }
        },
        {
          "name": "List All Memberships (admin)",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{adminToken}}", "type": "string" }] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/memberships", "host": ["{{baseUrl}}"], "path": ["memberships"] }
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Get My Payments",
          "request": {
            "method": "GET",
            "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }] },
            "header": [],
            "url": { "raw": "{{baseUrl}}/payments/me", "host": ["{{baseUrl}}"], "path": ["payments", "me"] }
          }
        }
      ]
    },
