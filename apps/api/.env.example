PORT=4000

# MySQL — XAMPP default root user has no password locally
DATABASE_URL="mysql://root:@localhost:3306/nahca_app"

JWT_SECRET=replace-with-a-long-random-string

# Demo/staging escape hatch — skips Stripe entirely and marks memberships/donations
# active immediately. Set to "false" (or remove) once real Stripe keys are added.
PAYMENTS_BYPASS=true

# Stripe (test mode keys — https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# SendGrid (https://app.sendgrid.com/settings/api_keys)
SENDGRID_API_KEY=SG.placeholder
SENDGRID_FROM_EMAIL=noreply@hinduchaplains.com

# Mailchimp (https://admin.mailchimp.com/account/api/)
MAILCHIMP_API_KEY=placeholder-us1
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_AUDIENCE_ID=placeholder

# Org details used on receipts / tax letters
ORG_NAME="North American Hindu Chaplains Association"
ORG_EIN="00-0000000"

# Frontend origin allowed to call this API
WEB_ORIGIN=http://localhost:3000
