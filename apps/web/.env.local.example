# Publicly reachable URL of apps/api, as seen from the visitor's browser
NEXT_PUBLIC_API_URL=http://localhost:4000

# Server-side only — used by NextAuth's Credentials provider to call the API
API_URL=http://localhost:4000

AUTH_SECRET=replace-with-a-long-random-string

# Must be this app's real public URL (e.g. https://portal.hinduchaplains.com)
# on any deployment other than local dev — NextAuth uses it to build sign-in
# redirect/callback URLs correctly.
NEXTAUTH_URL=http://localhost:3000
