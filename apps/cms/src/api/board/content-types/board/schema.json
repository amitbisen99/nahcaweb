{
  "kind": "collectionType",
  "collectionName": "board_members",
  "info": {
    "singularName": "board",
    "pluralName": "boards",
    "displayName": "Board Member",
    "description": "NAHCA board members shown on the About Us page"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
